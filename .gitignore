.DS_Store
**/.DS_Store

# Photos / images — excluded from git
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.heic
*.tiff
*.JPG
*.JPEG
*.PNG

# labeled/ is entirely photos
labeled/

# Large PDFs above GitHub's recommended 50MB limit
docs/hqd/hqd_spindle_motor_catalog_202504.pdf

# LinuxCNC runtime var files + local backups
*.var
*.bak
*.old/

# LinuxCNC GUI scratch state
*.halscope
*.preferences

# Mesa firmware binaries — re-downloadable from mesanet.com (see firmware/README.md).
# Keep README.md + the small .pin text maps; ignore the big zips/bitfiles.
firmware/**/*.zip
firmware/**/*.bin
firmware/**/*.bit
